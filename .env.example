# Firebase (get these from Firebase console → Project Settings → Your apps)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Server URL (Cloud Run URL after deployment, or localhost for dev)
EXPO_PUBLIC_SERVER_URL=http://localhost:3001
EXPO_PUBLIC_WS_URL=ws://localhost:3001/ws
