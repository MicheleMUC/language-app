# Gemini API key — get from Google AI Studio (aistudio.google.com)
GEMINI_API_KEY=

# Alternative: Vertex AI via Google Cloud (set project ID, leave GEMINI_API_KEY blank)
# GOOGLE_CLOUD_PROJECT=

# Supabase — for server-side learner profile writes (bypasses RLS)
# Get these from your Supabase project → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
